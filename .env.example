# Market Day — environment variables
# Set these in Netlify → Site configuration → Environment variables,
# or copy this file to ".env" for local scripts (backup/restore).

# Admin login passcode. CHANGE THIS from the shipped default.
# Must match the passcode used in the app. Applies to /api/data, /api/upload, /api/file.
ADMIN_PASSCODE=market26

# Used by the backup/restore scripts to reach your live site.
MARKET_DAY_URL=https://lifm-market-day.netlify.app

# Optional — only needed if Netlify Blobs auto-configuration is unavailable in your setup.
# Create at Netlify → User settings → Applications → Personal access tokens.
# NETLIFY_BLOBS_TOKEN=

# Optional — email notification when a vendor applies (if enabled in the function).
# RESEND_API_KEY=
# NOTIFY_EMAIL=you@example.com
